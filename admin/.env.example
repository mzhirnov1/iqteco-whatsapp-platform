MONGO_URL=mongodb://wa_admin:CHANGE_ME@127.0.0.1:27017/iqteco_wa?authSource=iqteco_wa
MONGO_DB=iqteco_wa
# URL мongo, видный изнутри podman-контейнеров (gateway IP бриджа wa-net).
# Если не задан, контейнерам прокидывается значение MONGO_URL — что обычно
# означает loopback 127.0.0.1 и обрывает соединение из контейнера.
CONTAINER_MONGO_URL=mongodb://10.89.0.1:27017/iqteco_wa

ADMIN_TOKEN=replace-with-64-hex-chars
ADMIN_BASE_URL=https://admin.wa.iqteco.com
API_BASE_URL=https://api.wa.iqteco.com

WA_IMAGE=ghcr.io/mzhirnov1/iqteco-whatsapp-platform/wa-instance:latest
TG_IMAGE=localhost/tg-instance:latest

IPV6_PREFIX=2a01:4f8:221:2d8d::
DEFAULT_WEBHOOK_URL=
APP_DEBUG=0

# Партнёрский токен для Partner API (создание инстансов c iqsmm.com и т.п.).
PARTNER_TOKEN=

# Wasabi S3 — обязательно для wa-instance (стартап-валидация падает на пустом
# S3_ACCESS_KEY/SECRET_KEY).
S3_ENDPOINT=https://s3.eu-west-2.wasabisys.com
S3_REGION=eu-west-2
S3_BUCKET=wa.iqteco.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_KEY_PREFIX=media/

# Telegram-приложение: https://my.telegram.org/auth → Apps → Create.
# Обязательно для tg-instance, иначе Telethon не сможет открыть сессию
# и QR не появится.
TG_API_ID=
TG_API_HASH=

# Поддержка (chat-виджет на legacy-портале).
LEGACY_SUPPORT_BASE_URL=
SUPPORT_SHARED_SECRET=
