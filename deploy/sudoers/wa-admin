# Sudo allowlist for www-data (admin.wa.iqteco.com PHP).
# Container names are validated in PodmanRunner (regex wa-\d{6,20}) before
# being passed to sudo, so the wildcards here are safe.
www-data ALL=(root) NOPASSWD: /usr/bin/podman run *
www-data ALL=(root) NOPASSWD: /usr/bin/podman stop *
www-data ALL=(root) NOPASSWD: /usr/bin/podman start *
www-data ALL=(root) NOPASSWD: /usr/bin/podman rm *
www-data ALL=(root) NOPASSWD: /usr/bin/podman logs *
www-data ALL=(root) NOPASSWD: /usr/bin/podman pause *
www-data ALL=(root) NOPASSWD: /usr/bin/podman unpause *
www-data ALL=(root) NOPASSWD: /usr/bin/podman exec *
www-data ALL=(root) NOPASSWD: /usr/bin/podman inspect *
www-data ALL=(root) NOPASSWD: /usr/bin/podman ps *
www-data ALL=(root) NOPASSWD: /usr/bin/systemctl start wa-instance@*
www-data ALL=(root) NOPASSWD: /usr/bin/systemctl stop wa-instance@*
www-data ALL=(root) NOPASSWD: /usr/bin/systemctl restart wa-instance@*
www-data ALL=(root) NOPASSWD: /usr/sbin/nginx -s reload
www-data ALL=(root) NOPASSWD: /usr/sbin/nft -j list counters
www-data ALL=(root) NOPASSWD: /usr/sbin/nft -j list table inet wa_traffic
www-data ALL=(root) NOPASSWD: /usr/local/bin/wa-nft-add-counter *
www-data ALL=(root) NOPASSWD: /usr/local/bin/wa-nft-del-counter *
www-data ALL=(root) NOPASSWD: /usr/local/bin/wa-nft-init-table
www-data ALL=(root) NOPASSWD: /usr/local/bin/wa-nginx-map-reload
www-data ALL=(root) NOPASSWD: /usr/local/bin/wa-nginx-map-deploy
